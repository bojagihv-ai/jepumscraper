# ─────────────────────────────────────────────────────────────
# JepumScraper 환경 변수 설정 예시
# 이 파일을 복사해서 .env 로 저장하고 실제 값을 채우세요
# ─────────────────────────────────────────────────────────────

# ── 네이버 개발자 API (선택) ──────────────────────────────────
NAVER_CLIENT_ID=your_naver_client_id_here
NAVER_CLIENT_SECRET=your_naver_client_secret_here

# ── CAPTCHA 해결 서비스 (선택 — 하나만 있어도 됨) ─────────────

# Capsolver (추천: 가장 빠름, Turnstile 지원 우수)
# 가입: https://capsolver.com
CAPSOLVER_API_KEY=

# 2captcha (범용, 24/7 서비스)
# 가입: https://2captcha.com
TWOCAPTCHA_API_KEY=

# Anti-Captcha
# 가입: https://anti-captcha.com
ANTICAPTCHA_API_KEY=

# ── 프록시 (선택) ─────────────────────────────────────────────
# SmartSession에서 사용하는 프록시 주소
# 형식: socks5://user:pass@host:port  또는  http://host:port
# PROXY_URL=socks5://user:pass@1.2.3.4:1080

# ProxyManager profiles (optional)
# Prefer the in-app settings JSON when you need platform/profile binding.
# Comma separated proxy URLs, used only when proxy profiles are enabled in settings.
# PROXY_LIST=http://user:pass@host1:8080,socks5://user:pass@host2:1080

# One proxy per line. Optional second column: residential, isp, mobile, datacenter.
# PROXY_FILE=C:\JepumScraper\data\proxy_profiles.txt

# Health check endpoint for validating proxy IP/latency.
# PROXY_HEALTH_CHECK_URL=https://api.ipify.org?format=json
# PROXY_HEALTH_TIMEOUT_SEC=8

# Optional AutoHotkey fallback for Coupang screen scrolling.
# Leave blank to auto-detect common install paths.
# ENABLE_AHK_FALLBACK=1
# AUTOHOTKEY_EXE=C:\Program Files\AutoHotkey\v2\AutoHotkey64.exe

# Optional Chrome profile selection.
# Leave NAVER_CHROME_PROFILE_DIRECTORY blank to auto-pick the recent profile
# that already has naver.com cookies. Example: Profile 2
# CHROME_PROFILE_DIRECTORY=Default
# NAVER_CHROME_PROFILE_DIRECTORY=
# If Naver redirects to login during detail capture, wait this many seconds
# so you can log in in the opened Chrome window and let capture continue.
# NAVER_LOGIN_WAIT_SEC=240
